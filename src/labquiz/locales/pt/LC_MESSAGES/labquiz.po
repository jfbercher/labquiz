msgstr "⚠️ A resposta {prop0} verdadeira implica que {prop1} seja verdadeira"

#: /Users/bercherj/JFB/dev/labquizdev/src/labquiz/main.py:893
#, python-brace-format
msgid "⚠️ The answer {prop0} true implies that {prop1} is necessarily false"
msgstr "⚠️ A resposta {prop0} verdadeira implica que {prop1} seja falsa"

#: /Users/bercherj/JFB/dev/labquizdev/src/labquiz/main.py:986
msgid "number is greater than the number of available questions"
msgstr "O número é superior ao número de perguntas disponíveis"

