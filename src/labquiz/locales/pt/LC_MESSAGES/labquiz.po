msgstr "Resposta errada &nbsp;&nbsp;❌ - "

#: /Users/bercherj/JFB/dev/labquizdev/src/labquiz/main.py:887
#, python-brace-format
msgid "⚠️ The answers to {props} are necessarily different"
msgstr "⚠️ As respostas a {props} são necessariamente diferentes"

