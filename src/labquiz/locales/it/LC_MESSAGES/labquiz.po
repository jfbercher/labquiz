msgid "<br>⚠️ No answers in quiz file: no score calculation."
msgstr ""
"<br>⚠️ Nessuna risposta nel file del quiz: nessun calcolo del punteggio."

#: /Users/bercherj/JFB/dev/labquizdev/src/labquiz/main.py:849
msgid "<br>⚠️ no answers in the quiz file: no possible correction."
msgstr "<br>⚠️ Nessuna risposta nel file del quiz: correzione impossibile."

#: /Users/bercherj/JFB/dev/labquizdev/src/labquiz/main.py:868
msgid "Good answer ✅ - "
msgstr "Ottima risposta ✅ - "

#: /Users/bercherj/JFB/dev/labquizdev/src/labquiz/main.py:871
msgid "Bad answer &nbsp;&nbsp;❌ - "
msgstr "Risposta sbagliata &nbsp;&nbsp;❌ - "

#: /Users/bercherj/JFB/dev/labquizdev/src/labquiz/main.py:887
#, python-brace-format
msgid "⚠️ The answers to {props} are necessarily different"
msgstr "⚠️ Le risposte a {props} devono essere necessariamente diverse"

#: /Users/bercherj/JFB/dev/labquizdev/src/labquiz/main.py:889
#, python-brace-format
msgid "⚠️ The answers to {props} are necessarily identical"
msgstr "⚠️ Le risposte a {props} devono essere necessariamente identiche"

#: /Users/bercherj/JFB/dev/labquizdev/src/labquiz/main.py:891
#, fuzzy, python-brace-format
msgid "⚠️ The answer {prop0} true implies that {prop1} is true"
msgstr "⚠️ La risposta {prop0} vera implica che {prop1} sia vera"

#: /Users/bercherj/JFB/dev/labquizdev/src/labquiz/main.py:893
#, python-brace-format
msgid "⚠️ The answer {prop0} true implies that {prop1} is necessarily false"
msgstr ""
"⚠️ La risposta {prop0} vera implica che {prop1} sia necessariamente falsa"

#: /Users/bercherj/JFB/dev/labquizdev/src/labquiz/main.py:986
msgid "number is greater than the number of available questions"
msgstr "Il numero è superiore al numero di domande disponibili"

